{
  "suggestSize": "2x4",
  "dataBindings": [
    {
      "bindingId": "today_events",
      "capabilityId": "calendar.events.search",
      "arguments": {
        "timeInterval": [1766448000000, 1766534399999]
      },
      "writeResultTo": "/data/calendar"
    }
  ],
  "refreshPlan": {
    "onInstall": ["today_events"],
    "onVisible": ["today_events"],
    "periodic": {
      "intervalSec": 1800,
      "bindings": ["today_events"]
    }
  }
}
