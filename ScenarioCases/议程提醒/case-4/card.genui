roundColor":"#FF0A59F7","fontSize":14,"fontWeight":500,"fontColor":"#FFFFFFFF"}},{"id":"badge","component":"Text","content":"{{ size($__dataModel.data.calendar.items) }}","styles":{"width":20,"height":20,"borderRadius":10,"backgroundColor":"#FFED6F21","fontSize":12,"fontWeight":700,"fontColor":"#FFFFFFFF","textAlign":"center","maxLines":1,"textOverflow":"none"}}]}}
