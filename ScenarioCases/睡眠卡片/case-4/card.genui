{"version":"v0.9","updateComponents":{"surfaceId":"sleepCard","root":"root","components":[{"id":"root","component":"Column","children":["topRow","heroRow","alarmBtn"],"itemMargin":6,"styles":{"width":140,"height":140,"padding":12,"borderRadius":18,"clip":true,"backgroundColor":"#fff1f3f5","justifyContent":"spaceBetween","alignItems":"start"}},{"id":"topRow","component":"Row","children":["sleepIcon","statusTitle"],"itemMargin":6,"wrap":"noWrap","styles":{"width":116,"height":20,"alignItems":"center"}},{"id":"sleepIcon","component":"Image","src":"resource/sleep_widget/icon_sleep.png","styles":{"width":18,"height":18,"objectFit":"contain"}},{"id":"statusTitle","component":"Text","content":"{{ $__dataModel.sleep.statusTitle }}","styles":{"width":92,"fontSize":14,"fontWeight":600,"fontColor":"{{ $__dataModel.sleep.hours < 7 ? '#ffe84026' : '#e5000000' }}","maxLines":1,"textOverflow":"none"}},{"id":"heroRow","component":"Row","children":["ringStack","hoursCol"],"itemMargin":10,"wrap":"noWrap","styles":{"width":116,"height":58,"alignItems":"center"}},{"id":"ringStack","component":"Stack","children":["ring"],"styles":{"width":56,"height":56,"alignContent":"center"}},{"id":"ring","component":"Progress","value":"{{ $__dataModel.sleep.hours }}","total":8,"styles":{"type":"ring","color":"#564af7","width":56,"height":56}},{"id":"hoursCol","component":"Column","children":["hoursValue","hoursLabel"],"itemMargin":2,"styles":{"width":50,"height":56,"justifyContent":"center","alignItems":"start"}},{"id":"hoursValue","component":"Text","content":"{{ $__dataModel.sleep.hoursLabel }}","styles":{"width":50,"fontSize":20,"fontWeight":700,"fontColor":"#e5000000","maxLines":1,"textOverflow":"none"}},{"id":"hoursLabel","component":"Text","content":"目标8小时","styles":{"width":50,"fontSize":10,"fontWeight":400,"fontColor":"#99000000","maxLines":1,"textOverflow":"none"}},{"id":"alarmBtn","component":"Button","label":"设置早睡提醒","onClick":[{"call":"clickToDeeplink","args":{"bundleName":"com.huawei.hmos.clock","abilityName":"com.huawei.hmos.clock.phone","uri":""}}],"styles":{"width":116,"height":28,"borderRadius":14,"backgroundColor":"#564af7","fontSize":14,"fontWeight":500,"fontColor":"#ffffffff"}}]}}
