{
  "suggestSize": "2x2",
  "dataBindings": [
    {
      "bindingId": "current_meeting",
      "capabilityId": "calendar.events.search",
      "arguments": {
        "timeInterval": [1766448000000, 1766534399999]
      },
      "writeResultTo": "/data/calendar"
    }
  ],
  "refreshPlan": {
    "onInstall": ["current_meeting"],
    "onVisible": ["current_meeting"],
    "periodic": {
      "intervalSec": 600,
      "bindings": ["current_meeting"]
    }
  }
}
