{"version":"v0.9","updateComponents":{"surfaceId":"rain_taxi_card","root":"root","components":[{"id":"root","component":"Row","children":["leftCol","midDivider","rightCol"],"itemMargin":10,"styles":{"width":300,"height":140,"padding":12,"borderRadius":22,"clip":true,"backgroundColor":"#FFEEF1F5","alignItems":"center"}},{"id":"leftCol","component":"Column","children":["wxRow","tempRow","taxiBtn"],"itemMargin":8,"styles":{"width":144,"height":116,"justifyContent":"spaceBetween","alignItems":"start"}},{"id":"wxRow","component":"Row","children":["wxIcon","wxText"],"itemMargin":6,"styles":{"width":144,"height":24,"alignItems":"center"}},{"id":"wxIcon","component":"Image","src":"resource/taxi_widget/icon_weathe2.png","styles":{"width":22,"height":22,"objectFit":"contain"}},{"id":"wxText","component":"Text","content":"{{ ${/data/weather/items/cityInfo/cityName} + ' · 小雨' }}","styles":{"width":116,"fontSize":14,"fontWeight":500,"fontColor":"#E5000000","maxLines":1,"textOverflow":"none"}},{"id":"tempRow","component":"Row","children":["tempText","tempUnit"],"itemMargin":2,"styles":{"width":144,"height":42,"alignItems":"bottom"}},{"id":"tempText","component":"Text","content":"{{ $__dataModel.data.weather.items.weatherData.temperature }}","styles":{"fontSize":40,"fontWeight":600,"fontColor":"#E5000000","maxLines":1,"textOverflow":"none"}},{"id":"tempUnit","component":"Text","content":"°C","styles":{"fontSize":16,"fontWeight":500,"fontColor":"#99000000","maxLines":1,"margin":{"bottom":6}}},{"id":"taxiBtn","component":"Row","children":["taxiIcon","taxiLabel"],"itemMargin":6,"styles":{"width":144,"height":34,"borderRadius":17,"backgroundColor":"#FF0A59F7","justifyContent":"center","alignItems":"center"}},{"id":"taxiIcon","component":"Image","src":"resource/taxi_widget/icon_car.png","styles":{"width":18,"height":18,"objectFit":"contain"}},{"id":"taxiLabel","component":"Text","content":"叫车去公司","styles":{"fontSize":14,"fontWeight":500,"fontColor":"#FFFFFFFF","maxLines":1,"textOverflow":"none"}},{"id":"midDivider","component":"Divider","styles":{"vertical":true,"strokeWidth":1,"color":"#22000000","height":96}},{"id":"rightCol","component":"Column","children":["schTitle","schList"],"itemMargin":8,"styles":{"width":108,"height":116,"justifyContent":"start","alignItems":"start"}},{"id":"schTitle","component":"Row","children":["schIcon","schTitleText"],"itemMargin":6,"styles":{"width":108,"height":20,"alignItems":"center"}},{"id":"schIcon","component":"Image","src":"resource/taxi_widget/icon_time1.png","styles":{"width":18,"height":18,"objectFit":"contain"}},{"id":"schTitleText","component":"Text","content":"今日日程","styles":{"width":84,"fontSize":14,"fontWeight":600,"fontColor":"#E5000000","maxLines":1,"textOverflow":"none"}},{"id":"schList","component":"Column","children":{"componentId":"schItemTpl","path":"/data/calendar/items"},"itemMargin":8,"styles":{"width":108,"height":88,"justifyContent":"start","alignItems":"start"}},{"id":"schItemTpl","component":"Column","children":["itemTime","itemTitle"],"itemMargin":2,"styles":{"width":108,"alignItems":"start"},"onClick":[{"call":"clickToIntent","args":{"intentName":"ViewCalendarEvent","params":{"entityId":{"path":"entityId"}}}}]},{"id":"itemTime","component":"Text","content":{"call":"formatString","args":{"value":"${dtStart}-${dtEnd}"}},"styles":{"width":108,"fontSize":12,"fontWeight":500,"fontColor":"#FF0A59F7","maxLines":1,"textOverflow":"none"}},{"id":"itemTitle","component":"Text","content":{"path":"title"},"styles":{"width":108,"fontSize":12,"fontWeight":400,"fontColor":"#99000000","maxLines":1,"textOverflow":"ellipsis"}}]}}
