{"version":"v0.9","updateComponents":{"surfaceId":"trip_card","root":"root","components":[{"id":"root","component":"Row","children":["weather_col","meeting_panel"],"itemMargin":8,"styles":{"width":300,"height":140,"padding":12,"borderRadius":22,"clip":true,"alignItems":"center","linearGradient":{"angle":160,"colors":[["#FFEAF1FB",0],["#FFD7E5F6",1]]}}},{"id":"weather_col","component":"Column","children":["city_row","temp_text","weather_label"],"itemMargin":6,"styles":{"width":150,"height":116,"justifyContent":"center","alignItems":"start"}},{"id":"city_row","component":"Row","children":["city_icon","city_text"],"itemMargin":4,"styles":{"width":150,"height":18,"alignItems":"center"}},{"id":"city_icon","component":"Image","src":"resource/taxi_widget/icon_weathe2.png","styles":{"width":16,"height":16,"objectFit":"contain"}},{"id":"city_text","component":"Text","content":"{{ $__dataModel.data.weather.items.cityInfo.prefectureName + ' · ' + $__dataModel.data.weather.items.weatherData.weather_icon }}","styles":{"width":130,"fontSize":12,"fontWeight":500,"fontColor":"#99000000","maxLines":1,"textOverflow":"ellipsis"}},{"id":"temp_text","component":"Text","content":"{{ $__dataModel.data.weather.items.weatherData.temperature + '°' }}","styles":{"width":150,"fontSize":40,"fontWeight":600,"fontColor":"#E5000000","maxLines":1,"textOverflow":"none"}},{"id":"weather_label","component":"Text","content":"{{ '体感 ' + $__dataModel.data.weather.items.weatherData.real_feel + '° · 湿度 ' + $__dataModel.data.weather.items.weatherData.humidity + '%' }}","styles":{"width":150,"fontSize":12,"fontWeight":400,"fontColor":"#99000000","maxLines":1,"textOverflow":"ellipsis"}},{"id":"meeting_panel","component":"Column","children":["meet_time","meet_title","meet_btn"],"itemMargin":6,"styles":{"width":118,"height":116,"padding":10,"borderRadius":16,"backgroundColor":"#FFFFFFFF","justifyContent":"center","alignItems":"start"}},{"id":"meet_time","component":"Text","content":"{{ $__dataModel.data.calendar.items.0.dtStart + ' 会议' }}","styles":{"width":98,"fontSize":14,"fontWeight":600,"fontColor":"#FF0A59F7","maxLines":1,"textOverflow":"none"}},{"id":"meet_title","component":"Text","content":"{{ $__dataModel.data.calendar.items.0.title }}","styles":{"width":98,"fontSize":12,"fontWeight":400,"fontColor":"#99000000","maxLines":2,"textOverflow":"ellipsis"}},{"id":"meet_btn","component":"Button","label":"查看会议","onClick":[{"call":"clickToIntent","args":{"intentName":"ViewCalendarEvent","params":{"entityId":"{{ ${/data/calendar/items/0/entityId} }}"}}}],"styles":{"width":98,"height":30,"borderRadius":15,"backgroundColor":"#FF0A59F7","fontSize":14,"fontWeight":500,"fontColor":"#FFFFFFFF"}}]}}
