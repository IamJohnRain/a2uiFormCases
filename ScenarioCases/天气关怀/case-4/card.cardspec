{
  "suggestSize": "2x4",
  "dataBindings": [
    {
      "bindingId": "weather_now",
      "capabilityId": "weather.overview.get",
      "arguments": {
        "prefectureName": "深圳市",
        "forecastDays": 1
      },
      "writeResultTo": "/data/weather"
    }
  ],
  "refreshPlan": {
    "onInstall": ["weather_now"],
    "onVisible": ["weather_now"],
    "periodic": {
      "intervalSec": 1800,
      "bindings": ["weather_now"]
    }
  }
}
