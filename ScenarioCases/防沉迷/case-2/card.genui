l","rec_value","rec_hint"],"itemMargin":2,"styles":{"width":104,"height":74,"padding":8,"borderRadius":14,"backgroundColor":"#19000000","justifyContent":"center","alignItems":"start"}},{"id":"rec_label","component":"Text","content":"建议限制","styles":{"width":84,"height":16,"fontSize":12,"fontWeight":400,"fontColor":"#99000000","maxLines":1,"textOverflow":"none"}},{"id":"rec_value","component":"Text","content":"{{ $__dataModel.recommend.limitLabel }}","styles":{"width":84,"height":22,"fontSize":18,"fontWeight":700,"fontColor":"#e5000000","maxLines":1,"textOverflow":"none"}},{"id":"rec_hint","component":"Text","content":"按近7天习惯","styles":{"width":84,"height":14,"fontSize":10,"fontWeight":400,"fontColor":"#66000000","maxLines":1,"textOverflow":"none"}},{"id":"focus_btn","component":"Button","label":"设专注","onClick":[{"call":"clickToDeeplink","args":{"bundleName":"com.huawei.hmos.settings","abilityName":"com.huawei.hmos.settings.MainAbility","uri":"intelligent_scene_entry"}}],"styles":{"width":104,"height":34,"borderRadius":17,"backgroundColor":"#ff0a59f7","fontSize":14,"fontWeight":500,"fontColor":"#ffffffff"}}]}}
